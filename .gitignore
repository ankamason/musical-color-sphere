# File patterns (NOT actual content)
diary.txt           # Ignores any file named diary.txt
journal/            # Ignores entire journal folder
*.private           # Ignores all files ending in .private
secrets/            # Ignores entire secrets folder
notes_*.txt         # Ignores notes_monday.txt, notes_tuesday.txt, etc
